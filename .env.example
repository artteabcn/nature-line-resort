# Resend — transactional email for both guests and owner alerts
# RESEND_FROM and OWNER_FROM_EMAIL must be on a verified Resend domain.
RESEND_API_KEY=
RESEND_FROM=noreply@pinkhousekohsamui.com

# Owner notification destination (booking + contact form alerts)
OWNER_EMAIL=bookings@pinkhousekohsamui.com
OWNER_FROM_EMAIL=noreply@pinkhousekohsamui.com

# Smoobu — REST API for native booking flow
# Get key from Smoobu dashboard → Settings → API
# Set in Cloudflare Pages → Environment Variables (production) and .env.local (dev)
SMOOBU_API_KEY=

# Cloudflare D1 (local dev — set in wrangler.toml, not here)
# Production D1 bindings are set in Cloudflare Pages dashboard
# Drizzle remote migrations need:
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# Stripe — full prepayment in THB (manual capture, captured after Smoobu confirms)
# Server-only secret (Cloudflare env): live and test keys both start with sk_
STRIPE_SECRET_KEY=
# Endpoint signing secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=
# Public key exposed to the browser via NEXT_PUBLIC_* prefix
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Places API — live reviews in the Memories Made Here section
# Get key from Google Cloud Console → APIs & Services → Credentials
# Enable "Places API (New)" on that key. Find your Place ID at:
#   https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# CMS / admin panel at /content (Cloudflare Access protects it at the edge)
# Public URL for the R2 MEDIA bucket — used to build <img src> for uploads.
# Either the bucket's r2.dev URL or a custom domain like media.pinkhousekohsamui.com.
MEDIA_PUBLIC_URL=
# Cloudflare Access team domain (e.g. "pinkhouse" from pinkhouse.cloudflareaccess.com)
CF_ACCESS_TEAM_DOMAIN=
# Cloudflare Access AUD tag — find in the Zero Trust dashboard → Access → Applications → your app
CF_ACCESS_AUD=
